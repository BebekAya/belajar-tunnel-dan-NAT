enable
configure terminal

! --- Konfigurasi Dasar & Routing RIP ---
interface f0/1
 ip address 11.11.11.2 255.255.255.252
 no shutdown
 exit

interface f0/0
 ip address 192.168.2.1 255.255.255.0
 no shutdown
 exit

router rip
 network 11.11.11.0
 network 192.168.2.0
 exit

! --- Konfigurasi NAT ---
ip route 0.0.0.0 0.0.0.0 11.11.11.1
access-list 1 permit any
ip nat inside source list 1 interface f0/1 overload

interface f0/1
 ip nat outside
 exit

interface f0/0
 ip nat inside
 exit

! --- Konfigurasi TUNNEL ---
interface tunnel 0
 ip address 172.168.100.2 255.255.255.0
 tunnel source f0/1
 tunnel destination 10.10.10.1
 exit

! --- Routing Static untuk Tunnel ---
ip route 192.168.1.0 255.255.255.0 172.168.100.1